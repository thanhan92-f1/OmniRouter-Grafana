# Monitoring stack environment for OmniRouter
# Copy to .env and change secrets before production use.

COMPOSE_PROJECT_NAME=omnirouter-monitoring

# Public OmniRouter URL. Use internal URL if stack runs on same Docker network.
OMNIROUTE_BASE_URL=https://platform.hitechcloud.one

# API key used only for /api/v1/* or /v1/* proxy endpoints if exporter needs them later.
# This is NOT accepted by management/dashboard endpoints.
OMNIROUTE_API_KEY=change-me

# Dashboard management auth uses cookie session auth_token.
# Exporter logs in with this password via POST /api/auth/login and reuses Set-Cookie.
# Use the current dashboard admin password. INITIAL_PASSWORD only works before password is changed.
OMNIROUTE_ADMIN_PASSWORD=change-me-dashboard-password

# Instance labels.
OMNIROUTE_INSTANCE=HiTechAI
OMNIROUTE_ENV=production

# Grafana login. Change before exposing Grafana.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-password

# Local host-side ports.
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
BLACKBOX_PORT=9115
OMNIROUTER_EXPORTER_PORT=9208

# Exporter calls many read-only management APIs. Keep timeout below Prometheus scrape_timeout.
SCRAPE_TIMEOUT_MS=20000

# Prometheus retention for local TSDB.
PROMETHEUS_RETENTION_TIME=30d

# Host log path mounted into Promtail.
# For Linux/VPS production this should normally be /var/lib/omniroute/logs
OMNIROUTE_LOGS_PATH=/var/lib/omniroute/logs
