# Monitoring stack environment for OmniRouter
# Copy to .env and change secrets before production use.

COMPOSE_PROJECT_NAME=omnirouter-monitoring

# Public OmniRouter URL. Use internal URL if stack runs on same Docker network.
OMNIROUTE_BASE_URL=https://platform.hitechcloud.one

# API key used by omnirouter-exporter to call management/usage endpoints.
# Prefer a dedicated read-only key if OmniRouter supports scopes.
OMNIROUTE_API_KEY=change-me

# Optional Bearer token for management endpoints if required.
OMNIROUTE_MANAGEMENT_TOKEN=

# Instance labels.
OMNIROUTE_INSTANCE=HiTechAI
OMNIROUTE_ENV=production

# Grafana login. Change before exposing Grafana.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-password

# Local host-side ports.
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
BLACKBOX_PORT=9115
OMNIROUTER_EXPORTER_PORT=9208

# Host log path mounted into Promtail.
# For Linux/VPS production this should normally be /var/lib/omniroute/logs
OMNIROUTE_LOGS_PATH=/var/lib/omniroute/logs
